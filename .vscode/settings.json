{
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript][javascriptreact][typescript][typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json][jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {
    "quickfix.biome": "explicit",
    "source.fixAll.sortJSON": "never",
    "source.organizeImports.biome": "explicit"
  },
  "editor.formatOnSave": true,
  "evenBetterToml.formatter.alignComments": true,
  "files.associations": {
    "**/dummy/mods/**/*.txt": "xml"
  },
  "files.exclude": {
    ".swc": true
    // "**/node_modules": true // optional
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.swc/**": true,
    "**/node_modules/**": true,
    "**/target/**": true
  },
  "i18n-ally.keystyle": "nested",
  "i18n-ally.localesPaths": ["locales", "gui/frontend/src/lib/i18n"],
  "json.schemas": [
    // https://github.com/SARDONYX-forks/d-merge-serde-hkx/blob/main/crates/havok_types/src/pointer.rs
    {
      "fileMatch": ["/dummy/convert/input/*.json", "/dummy/behavior_gen/output/.d_merge/.debug/meshes/**/*.json"],
      "url": "https://github.com/SARDONYX-sard/serde-hkx/raw/refs/tags/1.0.0/assets/serde_hkx_schema.json"
    }
  ],
  "rust-analyzer.cargo.targetDir": true,
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.linkedProjects": ["Cargo.toml"],
  "rust-analyzer.runnables.extraTestBinaryArgs": ["--show-output", "--nocapture"],
  "i18n-ally.sourceLanguage": "en"
}
