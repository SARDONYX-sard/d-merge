{
  "name": "d-merge",
  "version": "1.3.0",
  "private": true,
  "description": "patch",
  "homepage": "https://github.com/SARDONYX-sard/d-merge",
  "license": "GPL3.0",
  "workspaces": [
    "gui/tauri/frontend"
  ],
  "type": "module",
  "scripts": {
    "build": "rimraf ./gui/tauri/frontend/out && tauri build --no-bundle -- --profile release-no-lto",
    "build:release": "rimraf ./gui/tauri/frontend/out && tauri build --no-bundle -- --profile release",
    "build:front": "npm --workspace gui/tauri/frontend run build:front",
    "build:icons": "tauri icon ./gui/tauri/backend/icons/icon.svg",
    "dev": "tauri dev",
    "dev:front": "npm --workspace gui/tauri/frontend run dev:front",
    "fmt:front": "vp fmt --ignore-path ./.gitignore",
    "fmt:back": "cargo +nightly fmt --all",
    "fmt": "npm run fmt:front && npm run fmt:back",
    "lint": "vp lint ./ && cargo clippy --workspace",
    "lint:fix": "npm run fmt && vp check ./ --fix && cargo clippy --workspace --fix --allow-staged --allow-dirty",
    "tauri": "tauri",
    "test": "npm --workspace gui/tauri/frontend run test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.6.0",
    "rimraf": "^6",
    "typescript": "6.0.2",
    "vite-plus": "^0.1.18",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "why-is-node-running": "^3.2.2"
  },
  "overrides": {
    "monaco-editor": "0.49.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.5.2"
}
